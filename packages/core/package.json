{
  "name": "@shader-gradient/core",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Framework-agnostic animated shader gradients powered by Three.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "shader",
    "gradient",
    "three",
    "threejs",
    "webgl",
    "animation",
    "background"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "camera-controls": "^2.9.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "typescript": "^5.6.3"
  }
}
