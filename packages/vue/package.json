{
  "name": "@shader-gradient/vue",
  "type": "module",
  "version": "0.1.0",
  "description": "Vue bindings for @shader-gradient/core",
  "license": "MIT",
  "keywords": [
    "shader",
    "gradient",
    "vue",
    "three",
    "webgl",
    "animation",
    "background"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "vue-tsc --noEmit -p tsconfig.typecheck.json"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@shader-gradient/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
